{
  "name": "om-ai-pro",
  "displayName": "Om AI Pro",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/main/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "om-ai-sidebar",
          "title": "Om AI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "om-ai-sidebar": [
        {
          "id": "om-ai-chat-view",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "om-ai.openRules",
        "title": "Om AI: Open Project Rules (.om-ai-rules.md)",
        "category": "Om AI"
      },
      {
        "command": "om-ai.openChat",
        "title": "Om AI: Open Chat",
        "category": "Om AI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "om-ai.openChat",
          "group": "om-ai@1",
          "when": "editorHasSelection"
        }
      ],
      "commandPalette": [
        {
          "command": "om-ai.openRules"
        },
        {
          "command": "om-ai.openChat"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@types/vscode": "^1.109.0",
    "typescript": "^5.9.3"
  }
}
